# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# HubSpot (Private App token; optional alias: HUBSPOT_PRIVATE_APP_TOKEN)
# For auto-detecting booking/stack property internal names, add: crm.schemas.companies.read (and crm.schemas.contacts.read if stack lives on contacts)
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token
# Optional: comma-separated extra HubSpot property internal names for stack (we always request promptloop_booking_software = UI label "Promptloop - Booking Software", plus booking_software, booking_platform)
# HUBSPOT_BOOKING_SOFTWARE_PROPERTY_KEYS=custom_competitor_field

# Smartlead
SMARTLEAD_API_KEY=your_smartlead_api_key
# Optional: agency / multi-client accounts — same key may return 0 campaigns without this (see Smartlead API client_id on GET /campaigns/).
# SMARTLEAD_CLIENT_ID=12345
# Optional: max successful Smartlead enrollments per calendar day per logged-in user (this browser only; localStorage). Omit or 0 = unlimited.
# NEXT_PUBLIC_MAX_SENDS_PER_DAY=50

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
# Skip Gemini — use NEXT_PUBLIC_ so the browser never calls the model (avoids 429 during Send all)
# NEXT_PUBLIC_SKIP_GEMINI_PERSONALIZATION=true
# (Optional server-only alias for /api/generate: SKIP_GEMINI_PERSONALIZATION=true)

# Live HubSpot: real lists + contacts (requires HUBSPOT_ACCESS_TOKEN)
NEXT_PUBLIC_LIVE_OUTBOUND=true

# Smartlead test: console-only sends (no Add Lead API). Campaign list still loads from Smartlead when the API returns data.
# Mock campaigns in the picker only if the API returns none. Use with LIVE_OUTBOUND=true to demo HubSpot without enrolling.
# NEXT_PUBLIC_SMARTLEAD_TEST_MODE=true

# OpenAI (email generation)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# Optional: public context for email personalization (Places rating + Custom Search snippets)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
